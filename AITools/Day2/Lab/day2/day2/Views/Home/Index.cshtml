@model day2.Models.SortViewModel
@{
    ViewData["Title"] = "Quick Sort";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="card-title">Quick Sort Numbers</h2>
                <p class="text-muted">Enter a sequence of integers separated by spaces, commas, or semicolons (e.g. <code>1 2 3 12 32 45</code>).</p>

                @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }

                <form asp-action="Index" method="post">
                    <div class="mb-3">
                        <label for="Input" class="form-label">Numbers</label>
                        <input type="text" class="form-control form-control-lg" id="Input" name="Input" value="@Model?.Input" placeholder="Enter numbers..." />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">Sort</button>
                        <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary btn-lg">Reset</a>
                    </div>
                </form>

                @if (Model?.Sorted != null && Model.Sorted.Length > 0)
                {
                    <hr />
                    <h5>Results</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Original</h6>
                            <p class="p-2 bg-light border rounded">@String.Join(", ", Model.Original)</p>
                        </div>
                        <div class="col-md-6">
                            <h6>Sorted</h6>
                            <p class="p-2 bg-light border rounded">@String.Join(", ", Model.Sorted)</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
