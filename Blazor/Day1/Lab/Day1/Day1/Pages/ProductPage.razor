@page "/product"

<h1>Products Page</h1>

<span>Select Product : </span>
<select class="form-select mb-3" @bind="selectedId">
    @foreach(Product p in ProductsList)
    {
        <option value=@p.Id>@p.Name</option>
    }
</select>

<button class=" my-2 btn btn-primary" @onclick="showProduct">Show Product</button>



<div class="container">
    <div class="row justify-content-center align-items-center">
        @if (isVisible == true)
        {   <div class="col-3">
                <h2 class="my-3">Product Details : </h2>

                <div class="card" style="width: 18rem;">
                    <img class="card-img-top" src=@selectedProduct.ImageUrl alt="Card image cap">
                    <div class="card-body">
                        <h5 class="card-title">@selectedProduct.Name</h5>
                        <a href="#" class="btn btn-primary">Price : @selectedProduct.Price</a>
                    </div>
                </div>
            </div>

            <div class="col-5">
                <div>
                <span>Change Product Name</span>
                <input class="input-group"  @bind="selectedProduct.Name" @bind:event="oninput" type="text" />
                </div>
            </div>
        }
        @if(selectProductFlag == true)
        {
            <p class="text-warning">Select Product First</p>
        }
    </div>
</div>


@code {
    public int selectedId { set; get; }
    public bool isVisible { set; get; } = false;
    public bool selectProductFlag{ set; get; } = false;

    public Product selectedProduct { set; get; } = new Product();

    public Product myProduct { set; get; } = new Product { Name = "Potato", Id = 1, Quantity = 12, 
    ImageUrl = "https://shop.orange.eg/content/images/thumbs/0011674_iphone-16_550.jpeg",
    Price = 12.99M};

    public List<Product> ProductsList { set; get; } = new List<Product>();

    public ProductPage()
    {
        ProductsList.Add(new Product
            {
                Name = "Mobile Phone",
                Id = 1,
                Quantity = 10,
                ImageUrl = "https://shop.orange.eg/content/images/thumbs/0011674_iphone-16_550.jpeg",
                Price = 899.99M
            });
        ProductsList.Add(new Product
        {
            Name = "Playstation Console",
            Id = 2,
            Quantity = 10,
            ImageUrl = "https://shop.orange.eg/content/images/thumbs/0005845_sony-dualsense-wireless-controller-for-ps-5.png",
            Price = 299.99M
        });

        ProductsList.Add(new Product
        {
            Name = "Laptop",
            Id = 3,
            Quantity = 10,
            ImageUrl = "https://shop.orange.eg/content/images/thumbs/0006076_hp-pavilion-gaming-15-dk2112ne.jpeg",
            Price = 2599.99M
        });

        ProductsList.Add(new Product
        {
            Name = "Head Phones",
            Id = 4,
            Quantity = 10,
            ImageUrl = "https://shop.orange.eg/content/images/thumbs/0014926_jbl-tune-520bt.jpeg",
            Price = 199.99M
        });
    }


    public void showProduct()
    {
        selectedProduct = ProductsList.FirstOrDefault(p => p.Id == selectedId);
        Console.WriteLine(selectedId);
        if(selectedProduct != null)
        {
            isVisible = true;
            selectProductFlag = false;
        }
        else
        {
            selectProductFlag = true;
            isVisible = false;
            selectedProduct = new Product();
        }
    }


}
