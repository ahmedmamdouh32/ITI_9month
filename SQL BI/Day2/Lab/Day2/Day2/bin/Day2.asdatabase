          <Goal>100</Goal>
          <Status>case
    when kpivalue('QtyKPI') &gt; 100 then 1
    when kpivalue('QtyKPI') &lt; 100 then -1
    else 0
end</Status>
          <TrendGraphic>Standard Arrow</TrendGraphic>
          <StatusGraphic>Gauge - Ascending</StatusGraphic>
        </Kpi>
