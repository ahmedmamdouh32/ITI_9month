                            <Border>
                              <Color>LightGrey</Color>
                            </Border>
                            <BottomBorder>
                              <Style>Solid</Style>
                            </BottomBorder>
                            <BackgroundColor>=IIf(Fields!Grade.Value &lt; 50, "Red", 
     IIf(Fields!Grade.Value &gt;= 51 AND Fields!Grade.Value &lt;= 60, "Yellow", 
         IIf(Fields!Grade.Value &gt;= 61 AND Fields!Grade.Value &lt;= 100, "Green", "Transparent")))</BackgroundColor>
                            <FontFamily />
                            <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
