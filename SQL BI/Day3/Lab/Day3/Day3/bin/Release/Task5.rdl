  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Student</DataSourceName>
        <CommandText>select S.St_Id,S.St_Fname, S.St_Lname , c.Crs_Name, SC.Grade from student as S
inner join Stud_Course as SC
on S.St_Id = SC.St_Id
inner join Course as C 
on SC.Crs_Id = C.Crs_Id</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="St_Id">
          <DataField>St_Id</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="St_Fname">
          <DataField>St_Fname</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="St_Lname">
          <DataField>St_Lname</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Crs_Name">
          <DataField>Crs_Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Grade">
          <DataField>Grade</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
