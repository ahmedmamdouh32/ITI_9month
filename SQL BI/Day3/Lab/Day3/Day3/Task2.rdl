  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Student</DataSourceName>
        <CommandText>select T.*, C.Crs_Name from topic as T inner join Course as C
on T.Top_Id = c.Top_Id
order by T.Top_Name</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Top_Id">
          <DataField>Top_Id</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Top_Name">
          <DataField>Top_Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Crs_Name">
          <DataField>Crs_Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
